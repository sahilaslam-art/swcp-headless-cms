# Backend Port
PORT=5000

# MongoDB Connection String
PORT=5000
MONGODB_URI=mongodb://localhost:27017/swcp

# JWT Secret for Auth
JWT_SECRET=your_super_secret_jwt_key

# Node Environment (development or production)
NODE_ENV=development

# Allowed Origins for CORS (comma-separated URLs)
# For production (Vercel): https://your-admin-panel.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Production Backend URL (Used for SDK injection)
# For production (Railway): https://your-backend.up.railway.app
BACKEND_URL=http://localhost:5000
